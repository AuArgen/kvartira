generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Города ────────────────────────────────────────────────────────────────────

model City {
  id        Int      @id @default(autoincrement())
  name      String
  alias     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  districts District[]
  listings  Listing[]

  @@map("cities")
}

// ─── Районы ────────────────────────────────────────────────────────────────────

model District {
  id            Int      @id @default(autoincrement())
  cityId        Int      @map("city_id")
  name          String
  lalafoValueId Int?     @unique @map("lalafo_value_id")
  createdAt     DateTime @default(now()) @map("created_at")

  city     City      @relation(fields: [cityId], references: [id])
  listings Listing[]

  @@map("districts")
}

// ─── Пользователи (авторизация, свои объявления, лайки, комменты) ─────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String?  @unique
  username     String?
  passwordHash String?  @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  listings      Listing[]
  reactions     ListingReaction[]
  comments      ListingComment[]
  blockedBy     UserBlock[]    @relation("BlockedUser")
  blocking      UserBlock[]    @relation("BlockerUser")
  savedListings SavedListing[]

  @@map("users")
}

// ─── Объявления (Lalafo + свои) ────────────────────────────────────────────────

model Listing {
  id     Int    @id @default(autoincrement())
  // 'lalafo' — с сайта lalafo.kg | 'user' — собственное объявление
  source String @default("lalafo")

  // Lalafo-специфичные поля
  lalafoId  BigInt? @unique @map("lalafo_id")
  lalafoUrl String? @map("lalafo_url")

  // Для своих объявлений — владелец
  userId Int? @map("user_id")

  // Основные данные
  title       String
  description String? @db.Text

  // Цена
  price        Decimal? @db.Decimal(12, 2)
  oldPrice     Decimal? @map("old_price") @db.Decimal(12, 2)
  currency     String?  @default("KGS")
  isNegotiable Boolean  @default(false) @map("is_negotiable")
  priceType    Int?     @map("price_type")

  // Локация
  cityId     Int?     @map("city_id")
  districtId Int?     @map("district_id")
  cityName   String?  @map("city_name")
  lat        Decimal? @db.Decimal(10, 8)
  lng        Decimal? @db.Decimal(11, 8)

  // Контакт
  phone String?

  // Категория
  categoryId    Int?    @map("category_id")
  categoryLabel String? @map("category_label")

  // Количество комнат
  rooms Int?

  // Тип арендодателя: 'owner' (собственник) | 'realtor' (риэлтор/агентство) | null
  ownerType String? @map("owner_type")

  // Тип аренды: 'full' (целая квартира) | 'room' (комната/подселение) | null
  rentType String? @map("rent_type")

  // Платные фичи
  isVip     Boolean @default(false) @map("is_vip")
  isSelect  Boolean @default(false) @map("is_select")
  isPremium Boolean @default(false) @map("is_premium")

  // Статистика с Lalafo
  lalafoViews       Int? @map("lalafo_views")
  lalafoImpressions Int? @map("lalafo_impressions")
  lalafoFavorites   Int? @map("lalafo_favorites")

  // Статус: active | archived | deleted
  status String @default("active")

  // Временные метки Lalafo (для сортировки по "новизне" Lalafo)
  lalafoCreatedAt DateTime? @map("lalafo_created_at")
  lalafoUpdatedAt DateTime? @map("lalafo_updated_at")

  // Временные метки нашей базы
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city     City?     @relation(fields: [cityId], references: [id])
  district District? @relation(fields: [districtId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  images    ListingImage[]
  params    ListingParam[]
  reactions ListingReaction[]
  comments  ListingComment[]
  savedBy   SavedListing[]

  @@index([source])
  @@index([cityId])
  @@index([districtId])
  @@index([categoryId])
  @@index([status])
  @@index([price])
  @@index([lalafoCreatedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("listings")
}

// ─── Фотографии объявлений ─────────────────────────────────────────────────────

model ListingImage {
  id               Int      @id @default(autoincrement())
  listingId        Int      @map("listing_id")
  lalafoImageId    BigInt?  @map("lalafo_image_id")
  isMain           Boolean  @default(false) @map("is_main")
  originalUrl      String?  @map("original_url")
  thumbnailUrl     String?  @map("thumbnail_url")
  originalWebpUrl  String?  @map("original_webp_url")
  thumbnailWebpUrl String?  @map("thumbnail_webp_url")
  width            Int?
  height           Int?
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, isMain])
  @@map("listing_images")
}

// ─── Дополнительные параметры объявлений ──────────────────────────────────────

model ListingParam {
  id           Int     @id @default(autoincrement())
  listingId    Int     @map("listing_id")
  paramId      Int?    @map("param_id")
  paramName    String? @map("param_name")
  paramValue   String? @map("param_value")
  paramValueId Int?    @map("param_value_id")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_params")
}

// ─── Лог синхронизации с Lalafo ───────────────────────────────────────────────

model SyncLog {
  id                   Int       @id @default(autoincrement())
  startedAt            DateTime  @default(now()) @map("started_at")
  finishedAt           DateTime? @map("finished_at")
  pagesFetched         Int       @default(0) @map("pages_fetched")
  newListingsCount     Int       @default(0) @map("new_listings_count")
  updatedListingsCount Int       @default(0) @map("updated_listings_count")
  status               String    @default("running") // running | completed | failed
  errorMessage         String?   @map("error_message") @db.Text

  @@index([startedAt(sort: Desc)])
  @@map("sync_logs")
}

// ─── Лайки / Дизлайки ─────────────────────────────────────────────────────────

model ListingReaction {
  id           Int      @id @default(autoincrement())
  listingId    Int      @map("listing_id")
  userId       Int      @map("user_id")
  reactionType String   @map("reaction_type") // like | dislike
  createdAt    DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@map("listing_reactions")
}

// ─── Комментарии (с поддержкой вложенных ответов) ─────────────────────────────

model ListingComment {
  id        Int      @id @default(autoincrement())
  listingId Int      @map("listing_id")
  userId    Int      @map("user_id")
  parentId  Int?     @map("parent_id")
  content   String   @db.Text
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  ListingComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies ListingComment[] @relation("CommentReplies")

  @@index([listingId])
  @@map("listing_comments")
}

// ─── Блокировка пользователей (скрыть посты пользователя) ─────────────────────

model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId Int      @map("blocker_id")
  blockedId Int      @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("user_blocks")
}

// ─── Сохранённые / Избранные объявления ───────────────────────────────────────

model SavedListing {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  listingId Int      @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("saved_listings")
}
